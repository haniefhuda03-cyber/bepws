{
  "info": {
    "name": "TUWS Weather API",
    "description": "Collection untuk testing API Biasa dan API v3 dengan fitur CORS, Rate Limiting, dan X-API-KEY",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "your-api-key-here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "API Biasa (Legacy)",
      "description": "API Legacy di /api/* - Hanya menggunakan X-API-KEY, tanpa CORS dan Rate Limiting",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            },
            "description": "Cek kesehatan API (tidak perlu API key)"
          }
        },
        {
          "name": "Data General (Current Weather)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/data?type=general&source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "data"],
              "query": [
                {"key": "type", "value": "general"},
                {"key": "source", "value": "ecowitt"}
              ]
            }
          }
        },
        {
          "name": "Data Hourly (LSTM Prediction)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/data?type=hourly&model=lstm&limit=24",
              "host": ["{{base_url}}"],
              "path": ["api", "data"],
              "query": [
                {"key": "type", "value": "hourly"},
                {"key": "model", "value": "lstm"},
                {"key": "limit", "value": "24"}
              ]
            }
          }
        },
        {
          "name": "Data Hourly (XGBoost Prediction)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/data?type=hourly&model=xgboost",
              "host": ["{{base_url}}"],
              "path": ["api", "data"],
              "query": [
                {"key": "type", "value": "hourly"},
                {"key": "model", "value": "xgboost"}
              ]
            }
          }
        },
        {
          "name": "Data Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/data?type=detail&source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "data"],
              "query": [
                {"key": "type", "value": "detail"},
                {"key": "source", "value": "ecowitt"}
              ]
            }
          }
        },
        {
          "name": "History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/history?page=1&per_page=10&source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "history"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "per_page", "value": "10"},
                {"key": "source", "value": "ecowitt"}
              ]
            }
          }
        },
        {
          "name": "Graph Data",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/graph?range=weekly&datatype=temperature&source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "graph"],
              "query": [
                {"key": "range", "value": "weekly", "description": "REQUIRED: weekly or monthly"},
                {"key": "datatype", "value": "temperature", "description": "REQUIRED: temperature, humidity, rainfall, wind_speed, uvi, solar_radiation, relative_pressure"},
                {"key": "source", "value": "ecowitt"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "API v3 (RESTful)",
      "description": "API v3 di /api/v3/* - Dengan CORS, Rate Limiting, dan X-API-KEY",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v3/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "health"]
            },
            "description": "Cek kesehatan API v3 (tidak perlu API key). Perhatikan response header X-RateLimit-*"
          }
        },
        {
          "name": "Current Weather",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/current?source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "current"],
              "query": [
                {"key": "source", "value": "ecowitt"}
              ]
            },
            "description": "Lihat response header untuk rate limiting info"
          }
        },
        {
          "name": "Hourly Prediction (LSTM)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/hourly?model=lstm&limit=24",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "hourly"],
              "query": [
                {"key": "model", "value": "lstm"},
                {"key": "limit", "value": "24"}
              ]
            }
          }
        },
        {
          "name": "Hourly Prediction (XGBoost)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/hourly?model=xgboost",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "hourly"],
              "query": [
                {"key": "model", "value": "xgboost"}
              ]
            }
          }
        },
        {
          "name": "Weather Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/details?source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "details"],
              "query": [
                {"key": "source", "value": "ecowitt"}
              ]
            }
          }
        },
        {
          "name": "Weather History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/history?page=1&per_page=10&source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "history"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "per_page", "value": "10"},
                {"key": "source", "value": "ecowitt"}
              ]
            }
          }
        },
        {
          "name": "Graph Data",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/graph?range=weekly&datatype=temperature&source=ecowitt",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "graph"],
              "query": [
                {"key": "range", "value": "weekly", "description": "REQUIRED: weekly or monthly"},
                {"key": "datatype", "value": "temperature", "description": "REQUIRED"},
                {"key": "source", "value": "ecowitt"}
              ]
            }
          }
        },
        {
          "name": "Test CORS (Preflight)",
          "request": {
            "method": "OPTIONS",
            "header": [
              {
                "key": "Origin",
                "value": "http://localhost:3000",
                "type": "text"
              },
              {
                "key": "Access-Control-Request-Method",
                "value": "GET",
                "type": "text"
              },
              {
                "key": "Access-Control-Request-Headers",
                "value": "X-API-KEY",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/current",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "current"]
            },
            "description": "Test CORS preflight request. Lihat response headers Access-Control-*"
          }
        },
        {
          "name": "Test Rate Limiting",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "health"]
            },
            "description": "Jalankan berulang kali dan perhatikan header:\n- X-RateLimit-Limit: 100\n- X-RateLimit-Remaining: berkurang setiap request\n- X-RateLimit-Reset: timestamp reset"
          }
        },
        {
          "name": "Test Invalid API Key",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "invalid-key",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/current",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "current"]
            },
            "description": "Test dengan API key yang salah - harus return 401"
          }
        },
        {
          "name": "Test Missing API Key",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v3/weather/current",
              "host": ["{{base_url}}"],
              "path": ["api", "v3", "weather", "current"]
            },
            "description": "Test tanpa API key - harus return 401"
          }
        }
      ]
    }
  ]
}
