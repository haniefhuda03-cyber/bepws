# ============================================================
# TUWS Backend - Environment Variables Template
# ============================================================
# Salin file ini menjadi .env dan isi sesuai konfigurasi Anda
# cp .env.example .env
# ============================================================

# DATABASE (WAJIB)
DATABASE_URL="postgresql://postgres:password@localhost:5432/tuws_pws"

# FLASK
FLASK_APP=run.py
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# CONSOLE endpoint menggunakan port yang sama dengan Flask (FLASK_PORT)\nCONSOLE_IP_WHITELIST="192.168.4.1"

# KEAMANAN
SECRET_KEY="ganti-dengan-random-string-yang-panjang"
API_READ_KEY="tuws2526"

# WEATHER API KEYS (isi sesuai akun Anda)
WUNDERGROUND_URL="https://api.weather.com/v2/pws/observations/current?stationId=YOUR_STATION&format=json&units=m&numericPrecision=decimal&apiKey=YOUR_KEY"
ECO_APP_KEY="your-ecowitt-app-key"
ECO_API_KEY="your-ecowitt-api-key"
ECO_MAC="your-device-mac"

# CACHE (opsional - tanpa Redis, pakai in-memory)
# REDIS_URL="redis://localhost:6379/0"
# REDIS_URL="redis://:password@hostname:6379/0"  # dengan auth
# REDIS_PASSWORD="changeme"  # harus sama dengan docker-compose

# CORS
CORS_ORIGINS="*"

# RATE LIMITING
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# API Config
STATION_LOCATION="Sukapura"
